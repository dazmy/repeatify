{
  "manifest_version": 2,
  "name": "Repeatify",
  "version": "1.5",
  "description": "Manage repeat song for Youtube Music.",
  "icons": {
    "48": "icons/repeatify-48.png"
  },
  "permissions": ["activeTab", "tabs", "*://music.youtube.com/", "storage"],
  "browser_action": {
    "default_icon": "icons/repeatify-32.png",
    "default_title": "Repeatify",
    "default_popup": "popup/repeatify.html"
  },
  "content_scripts": [
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["content_scripts/utils.js", "content_scripts/repeatify_cs.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": { "id": "{83ae1fd1-7306-4de4-adbf-850bb88a388c}" }
  },
  "background": {
    "scripts": ["background/background.js"],
    "persistent": false,
    "type": "module"
  },
  "commands": {
    "play-pause": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "windows": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "play / pause song"
    },
    "loop": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "windows": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "repeat / no-repeat current song"
    },
    "change-image": {
      "suggested_key": {
        "default": "Alt+Shift+Y",
        "windows": "Alt+Shift+Y",
        "mac": "Alt+Shift+Y"
      },
      "description": "change song image to random / default"
    }
  }
}
